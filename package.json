{
	"name": "sayit-hono",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "bun run deploy:search",
		"deploy:assets": "bun run build:cache-version && bun run build:views && bun run build:assets && npx wrangler deploy && bun run verify:deploy",
		"deploy:search": "bun run build:cache-version && bun run build:views && bun run build:assets && bun run build:search && npx wrangler deploy && bun run verify:deploy",
		"dev": "bun run build:views && wrangler dev --remote",
		"verify:deploy": "tsx --tsconfig scripts/tsconfig.json scripts/verify-deploy.ts",
		"build:cache-version": "tsx --tsconfig scripts/tsconfig.json scripts/generate-cache-version.ts",
		"start": "bun run dev",
		"build:views": "tsx --tsconfig scripts/tsconfig.json scripts/build-views.ts",
		"build:assets": "tsx --tsconfig scripts/tsconfig.json scripts/build-assets.ts",
		"build:search": "tsx --tsconfig scripts/tsconfig.json scripts/build-search-index.ts",
		"preview:assets": "bun run build:assets && python3 -m http.server 4173 -d www",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"typecheck": "tsgo --noEmit",
		"cf-typegen": "wrangler types"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.71",
		"@types/node": "^24.12.2",
		"@typescript/native-preview": "^7.0.0-dev.20260429.1",
		"@vitest/coverage-istanbul": "^3.2.4",
		"@vue/compiler-sfc": "^3.5.33",
		"fuse.js": "^7.3.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "~3.2.4",
		"wrangler": "4.76.0"
	},
	"dependencies": {
		"@resvg/resvg-wasm": "^2.6.2",
		"@vue/server-renderer": "^3.5.33",
		"cheerio": "^1.2.0",
		"hono": "^4.12.15",
		"marked": "^17.0.6",
		"satori": "^0.26.0",
		"vue": "^3.5.33"
	}
}
